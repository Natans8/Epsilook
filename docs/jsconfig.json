{
  // Dev-time type checking only — nothing here is part of serving the app.
  // Files opt in with a leading // @ts-check comment; shared shapes live in
  // js/types.d.ts. Check from the repo root with:
  //   npx -p typescript tsc -p docs/jsconfig.json
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "checkJs": false,
    // deliberate: structural/type errors without null-check noise — the DOM
    // code derefs elements that provably exist in index.html
    "strict": false,
    "noEmit": true
  },
  "include": ["js/*.js", "js/types.d.ts"],
  // vendored libs are checked upstream; types.d.ts declares BLPFile for them
  "exclude": ["js/bufo.js", "js/js-blp.js"]
}
